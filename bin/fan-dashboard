#!/usr/bin/env python3
import argparse
import csv
import html
import json
import os
import subprocess
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path


HWMON_ROOT = Path("/sys/class/hwmon")


def read_text(path):
    try:
        return Path(path).read_text(encoding="utf-8").strip()
    except OSError:
        return None


def read_float(path, scale=1.0):
    value = read_text(path)
    if value is None:
        return None
    try:
        return float(value) / scale
    except ValueError:
        return None


def nvidia_gpus():
    fields = [
        "index",
        "name",
        "temperature.gpu",
        "fan.speed",
        "power.draw",
        "utilization.gpu",
    ]
    cmd = [
        "nvidia-smi",
        f"--query-gpu={','.join(fields)}",
        "--format=csv,noheader,nounits",
    ]
    try:
        proc = subprocess.run(
            cmd,
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=3,
        )
    except (FileNotFoundError, subprocess.SubprocessError):
        return []

    rows = []
    for row in csv.reader(proc.stdout.splitlines()):
        if len(row) != len(fields):
            continue
        values = [item.strip() for item in row]
        rows.append(
            {
                "kind": "gpu",
                "index": values[0],
                "name": values[1],
                "temperature_c": values[2],
                "fan_percent": values[3],
                "power_w": values[4],
                "utilization_percent": values[5],
            }
        )
    return rows


def hwmon_fans():
    fans = []
    if not HWMON_ROOT.exists():
        return fans

    for hwmon in sorted(HWMON_ROOT.glob("hwmon*")):
        chip = read_text(hwmon / "name") or hwmon.name
        for fan_input in sorted(hwmon.glob("fan*_input")):
            fan_num = fan_input.name.removeprefix("fan").removesuffix("_input")
            rpm = read_float(fan_input)
            if rpm is None:
                continue
            label = read_text(hwmon / f"fan{fan_num}_label") or f"fan{fan_num}"
            fans.append(
                {
                    "kind": "motherboard",
                    "chip": chip,
                    "label": label,
                    "rpm": int(rpm),
                }
            )
    return fans


def snapshot():
    return {
        "hostname": os.uname().nodename,
        "gpus": nvidia_gpus(),
        "fans": hwmon_fans(),
    }


def cell(value, suffix=""):
    if value is None or value == "":
        return '<span class="muted">n/a</span>'
    return f"{html.escape(str(value))}{suffix}"


def render_page(data):
    gpu_rows = "\n".join(
        f"""
        <tr>
          <td>GPU {html.escape(gpu["index"])}</td>
          <td>{html.escape(gpu["name"])}</td>
          <td>{cell(gpu["fan_percent"], "%")}</td>
          <td>{cell(gpu["temperature_c"], " C")}</td>
          <td>{cell(gpu["power_w"], " W")}</td>
          <td>{cell(gpu["utilization_percent"], "%")}</td>
        </tr>
        """
        for gpu in data["gpus"]
    ) or '<tr><td colspan="6" class="muted">No NVIDIA GPU fan telemetry found.</td></tr>'

    fan_rows = "\n".join(
        f"""
        <tr>
          <td>{html.escape(fan["chip"])}</td>
          <td>{html.escape(fan["label"])}</td>
          <td>{cell(fan["rpm"], " RPM")}</td>
        </tr>
        """
        for fan in data["fans"]
    ) or '<tr><td colspan="3" class="muted">No motherboard fan RPMs exposed yet.</td></tr>'

    return f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="refresh" content="5">
  <title>Fan Dashboard</title>
  <style>
    :root {{
      color-scheme: dark;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #111318;
      color: #eef1f5;
    }}
    body {{
      margin: 0;
      padding: 24px;
    }}
    main {{
      max-width: 980px;
      margin: 0 auto;
    }}
    header {{
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: baseline;
      margin-bottom: 24px;
    }}
    h1 {{
      font-size: clamp(1.7rem, 4vw, 2.6rem);
      margin: 0;
      letter-spacing: 0;
    }}
    h2 {{
      margin: 28px 0 10px;
      font-size: 1rem;
      letter-spacing: 0;
      color: #b8c3d6;
      text-transform: uppercase;
    }}
    table {{
      width: 100%;
      border-collapse: collapse;
      background: #181c24;
      border: 1px solid #2a3140;
      border-radius: 8px;
      overflow: hidden;
    }}
    th, td {{
      padding: 12px 14px;
      text-align: left;
      border-bottom: 1px solid #2a3140;
      white-space: nowrap;
    }}
    th {{
      color: #aeb9ca;
      font-weight: 600;
      background: #202633;
    }}
    tr:last-child td {{
      border-bottom: 0;
    }}
    .muted {{
      color: #8793a6;
    }}
    .note {{
      color: #aeb9ca;
      line-height: 1.5;
      margin-top: 18px;
    }}
    @media (max-width: 680px) {{
      body {{ padding: 14px; }}
      header {{ display: block; }}
      table {{ display: block; overflow-x: auto; }}
    }}
  </style>
</head>
<body>
  <main>
    <header>
      <h1>Fan Dashboard</h1>
      <div class="muted">{html.escape(data["hostname"])} · refreshes every 5s</div>
    </header>

    <h2>GPU Fans</h2>
    <table>
      <thead>
        <tr>
          <th>Slot</th>
          <th>Name</th>
          <th>Fan</th>
          <th>Temp</th>
          <th>Power</th>
          <th>Load</th>
        </tr>
      </thead>
      <tbody>{gpu_rows}</tbody>
    </table>

    <h2>Motherboard Fans</h2>
    <table>
      <thead>
        <tr>
          <th>Sensor</th>
          <th>Fan</th>
          <th>Speed</th>
        </tr>
      </thead>
      <tbody>{fan_rows}</tbody>
    </table>

    <p class="note">
      Zero GPU fan speed usually means the card is in fan-stop mode, not that telemetry failed.
      If motherboard fans are missing, install and configure lm-sensors so the board's monitoring chip is exposed to Linux.
    </p>
  </main>
</body>
</html>"""


class Handler(BaseHTTPRequestHandler):
    def _handle(self, include_body):
        data = snapshot()
        if self.path == "/json":
            body = json.dumps(data, indent=2).encode("utf-8")
            content_type = "application/json; charset=utf-8"
        else:
            body = render_page(data).encode("utf-8")
            content_type = "text/html; charset=utf-8"

        self.send_response(200)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        if include_body:
            self.wfile.write(body)

    def do_GET(self):
        self._handle(include_body=True)

    def do_HEAD(self):
        self._handle(include_body=False)

    def log_message(self, fmt, *args):
        return


def main():
    parser = argparse.ArgumentParser(description="Tiny fan telemetry dashboard.")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", default=8765, type=int)
    args = parser.parse_args()

    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"Fan dashboard listening on http://{args.host}:{args.port}")
    server.serve_forever()


if __name__ == "__main__":
    main()
